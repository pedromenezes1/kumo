{
  "jsPlugins": [
    "./lint/kumo-plugin.js",
    {
      "name": "jsx-a11y-js",
      "specifier": "eslint-plugin-jsx-a11y"
    }
  ],
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "kumo/no-tailwind-dark-variant": "error",
    "kumo/no-primitive-colors": "error",
    "kumo/enforce-variant-standard": "error",
    "kumo/no-deprecated-props": "error",
    "kumo/no-cross-package-imports": "error",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-unnecessary-template-expression": "off",
    "typescript/no-unnecessary-type-assertion": "off",
    "jsx-a11y/no-autofocus": "off",
    // These unicorn rules auto-fix .sort()/.reverse() to .toSorted()/.toReversed()
    // (ES2023). The library still needs to avoid newer runtime Array APIs in
    // published dist output, so keep the source rule off and let the post-build
    // browser-compat test catch regressions instead.
    "unicorn/no-array-sort": "off",
    "unicorn/no-array-reverse": "off",
    // --- Native oxlint jsx-a11y rules (now implemented) ---
    "jsx-a11y/aria-proptypes": "error",
    "jsx-a11y/no-static-element-interactions": "error",
    // --- JS plugin rules (not yet native in oxlint) ---
    // https://github.com/oxc-project/oxc/issues/1141
    "jsx-a11y-js/interactive-supports-focus": "error",
    "jsx-a11y-js/no-interactive-element-to-noninteractive-role": "error",
    "jsx-a11y-js/no-noninteractive-element-interactions": "error",
    "jsx-a11y-js/no-noninteractive-element-to-interactive-role": "error",
    "jsx-a11y-js/control-has-associated-label": "warn"
  }
}
